{
  "name": "SFTerm",
  "version": "8.12.3",
  "description": "旗鱼终端 - AI 驱动的跨平台终端",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder && node scripts/fix-mac-yml.js",
    "build:win": "vue-tsc --noEmit && vite build && electron-builder --win --publish never",
    "build:mac": "vue-tsc --noEmit && vite build && electron-builder --mac --publish never && node scripts/fix-mac-yml.js",
    "build:linux": "vue-tsc --noEmit && vite build && electron-builder --linux --publish never",
    "build:win:fast": "vite build && electron-builder --win",
    "build:mac:fast": "vite build && electron-builder --mac && node scripts/fix-mac-yml.js",
    "build:linux:fast": "vite build && electron-builder --linux",
    "build:dir": "vite build && electron-builder --dir",
    "typecheck": "vue-tsc --noEmit",
    "typecheck:electron": "tsc --project tsconfig.node.json --noEmit",
    "typecheck:src": "vue-tsc --noEmit --skipLibCheck",
    "check": "npm run typecheck && npm run lint:check",
    "check:fast": "npm run typecheck:src",
    "build:check": "vue-tsc --noEmit && vite build --mode production",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx --fix",
    "lint:check": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx",
    "format": "prettier --write src/",
    "preversion": "node scripts/preversion.js",
    "postversion": "node scripts/postversion.js",
    "generate-icons": "node scripts/generate-icons.js",
    "build:steam:win": "vite build && electron-builder --win --dir --publish never",
    "build:steam:mac": "vite build && electron-builder --mac --dir --publish never",
    "build:steam:linux": "vite build && electron-builder --linux --dir --publish never",
    "build:steam:current": "vite build && electron-builder --dir --publish never"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.22.3",
    "@langchain/textsplitters": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "@xenova/transformers": "^2.17.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-search": "^0.15.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "apache-arrow": "^18.1.0",
    "docx": "^9.5.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.7",
    "exceljs": "^4.4.0",
    "https-proxy-agent": "^7.0.4",
    "iconv-lite": "^0.7.0",
    "imapflow": "^1.2.4",
    "jieba-wasm": "^2.4.0",
    "keytar": "^7.9.0",
    "lucide-vue-next": "^0.562.0",
    "mailparser": "^3.9.1",
    "mammoth": "^1.11.0",
    "marked": "^12.0.0",
    "node-pty": "^1.0.0",
    "nodemailer": "^7.0.12",
    "pdf-parse": "^2.4.5",
    "pdf2json": "^4.0.0",
    "pinia": "^2.1.7",
    "playwright-core": "^1.57.0",
    "socks-proxy-agent": "^8.0.2",
    "ssh2": "^1.15.0",
    "ssh2-sftp-client": "^12.0.1",
    "strip-ansi": "^7.1.2",
    "uuid": "^9.0.1",
    "vue": "^3.4.21",
    "vue-i18n": "^9.14.5",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@rushstack/eslint-patch": "^1.7.2",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.11.24",
    "@types/nodemailer": "^7.0.4",
    "@types/ssh2": "^1.15.0",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/eslint-config-prettier": "^9.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.22.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.6"
  },
  "author": {
    "name": "旗鱼",
    "email": "nuoyan_cfan@163.com"
  },
  "license": "AGPL-3.0"
}
