---
import { useTranslations, type Lang } from '../i18n/utils';
import { defaultLanguage } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = defaultLanguage } = Astro.props;
const t = useTranslations(lang);
const v = t.guide.visionRouting;
---

<section class="guide-section">
  <div class="container">
    <h1 class="section-title">{t.guide.title}</h1>
    <p class="section-subtitle">{t.guide.subtitle}</p>

    <div class="guide-layout">
      <!-- 侧边目录 -->
      <nav class="guide-toc">
        <h3 class="toc-title">{t.guide.toc}</h3>
        <ul class="toc-list">
          <li><a href="#vision-routing" class="toc-link active">{v.title}</a></li>
        </ul>
      </nav>

      <!-- 文档正文 -->
      <article class="guide-content">
        <section id="vision-routing" class="guide-article">
          <h2 class="article-title">{v.title}</h2>
          <p class="article-intro">{v.intro}</p>

          <!-- 工作原理 -->
          <h3>{v.howItWorks}</h3>
          <p>{v.howItWorksDesc}</p>
          <div class="flow-steps">
            {v.flowSteps.map((step, i) => (
              <div class="flow-step">
                <span class="flow-step-num">{i + 1}</span>
                <span class="flow-step-text">{step}</span>
              </div>
            ))}
          </div>

          <!-- 配置方法 -->
          <h3>{v.setup}</h3>
          <ol class="setup-steps">
            {v.setupSteps.map(step => (
              <li>{step}</li>
            ))}
          </ol>

          <!-- 使用场景 -->
          <h3>{v.example}</h3>
          <p>{v.exampleDesc}</p>
          <div class="example-scenarios">
            {v.exampleScenarios.map(scenario => (
              <div class="scenario">
                <div class="scenario-input">{scenario.input}</div>
                <div class="scenario-result">{scenario.result}</div>
              </div>
            ))}
          </div>

          <!-- 使用建议 -->
          <h3>{v.tips}</h3>
          <ul class="tips-list">
            {v.tipsList.map(tip => (
              <li>{tip}</li>
            ))}
          </ul>
        </section>
      </article>
    </div>
  </div>
</section>

<style>
  .guide-section {
    padding: calc(var(--spacing-section) + 60px) 0 var(--spacing-section);
    min-height: 100vh;
  }

  .guide-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 48px;
    max-width: 960px;
    margin: 0 auto;
  }

  /* 侧边目录 */
  .guide-toc {
    position: sticky;
    top: 100px;
    align-self: start;
  }

  .toc-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 16px;
  }

  .toc-list {
    list-style: none;
    border-left: 2px solid var(--color-border);
    padding-left: 16px;
  }

  .toc-list li {
    margin-bottom: 8px;
  }

  .toc-link {
    display: block;
    font-size: 14px;
    color: var(--color-text-secondary);
    padding: 4px 0;
    transition: color 0.2s;
  }

  .toc-link:hover,
  .toc-link.active {
    color: var(--color-accent-primary);
  }

  .toc-link.active {
    font-weight: 500;
  }

  /* 文档正文 */
  .guide-content {
    min-width: 0;
  }

  .guide-article {
    line-height: 1.8;
  }

  .article-title {
    font-size: 28px;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-border);
  }

  .article-intro {
    font-size: 16px;
    color: var(--color-text-secondary);
    margin-bottom: 36px;
    line-height: 1.8;
  }

  .guide-article h3 {
    font-size: 20px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin: 36px 0 16px;
  }

  .guide-article p {
    color: var(--color-text-secondary);
    margin-bottom: 16px;
  }

  /* 流程步骤 */
  .flow-steps {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 20px 0 32px;
  }

  .flow-step {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 18px;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    transition: border-color 0.2s;
  }

  .flow-step:hover {
    border-color: var(--color-border-hover);
  }

  .flow-step-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--gradient-primary);
    color: white;
    font-size: 13px;
    font-weight: 700;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .flow-step-text {
    font-size: 14px;
    color: var(--color-text-secondary);
  }

  /* 配置步骤 */
  .setup-steps {
    margin: 16px 0 32px;
    padding-left: 20px;
  }

  .setup-steps li {
    color: var(--color-text-secondary);
    font-size: 15px;
    margin-bottom: 12px;
    padding-left: 8px;
  }

  .setup-steps li::marker {
    color: var(--color-accent-primary);
    font-weight: 600;
  }

  /* 使用场景 */
  .example-scenarios {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 20px 0 32px;
  }

  .scenario {
    display: flex;
    align-items: center;
    gap: 0;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .scenario-input {
    flex: 1;
    padding: 14px 18px;
    font-size: 14px;
    color: var(--color-text-secondary);
    font-family: var(--font-sans);
  }

  .scenario-result {
    padding: 14px 18px;
    font-size: 14px;
    font-weight: 500;
    color: var(--color-accent-primary);
    background: rgba(6, 182, 212, 0.05);
    border-left: 1px solid var(--color-border);
    white-space: nowrap;
  }

  /* 使用建议 */
  .tips-list {
    margin: 16px 0 32px;
    padding-left: 20px;
  }

  .tips-list li {
    color: var(--color-text-secondary);
    font-size: 15px;
    margin-bottom: 12px;
    padding-left: 8px;
  }

  .tips-list li::marker {
    color: var(--color-accent-primary);
  }

  /* 响应式 */
  @media (max-width: 768px) {
    .guide-layout {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .guide-toc {
      position: static;
      padding: 16px;
      background: var(--color-bg-card);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
    }

    .toc-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px 16px;
      border-left: none;
      padding-left: 0;
    }

    .toc-list li {
      margin-bottom: 0;
    }

    .article-title {
      font-size: 22px;
    }

    .scenario {
      flex-direction: column;
    }

    .scenario-result {
      border-left: none;
      border-top: 1px solid var(--color-border);
      width: 100%;
      white-space: normal;
    }
  }
</style>
