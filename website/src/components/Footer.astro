---
import { useTranslations, type Lang } from '../i18n/utils';
import { defaultLanguage } from '../i18n/translations';

interface Props {
  lang?: Lang;
}

const { lang = defaultLanguage } = Astro.props;
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <picture>
          <source srcset="/logo.webp" type="image/webp" />
          <img src="/logo.png" alt={t.common.brandName} class="footer-logo" />
        </picture>
        <span>{t.common.brandName}</span>
      </div>

      <div class="footer-links">
        <a href="https://github.com/ysyx2008/SailFish" target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          {t.footer.links.github}
        </a>
        <a href="https://github.com/ysyx2008/SailFish/issues" target="_blank" rel="noopener">{t.footer.links.issues}</a>
        <a href="#" class="qq-group-link" data-group="1078041072" title="1078041072">{t.footer.links.qqGroup}</a>
        <a href="https://github.com/ysyx2008/SailFish/blob/main/LICENSE" target="_blank" rel="noopener">{t.footer.links.license}</a>
        <a href="mailto:nuoyan_cfan@163.com">{t.footer.commercial.contact}</a>
      </div>

      <p class="copyright">
        © {currentYear} {t.common.brandName}. {t.footer.copyright}
        <span class="copyright-sep">·</span>
        <a href="https://github.com/ysyx2008/SailFish/blob/main/LICENSE" target="_blank" rel="noopener" class="copyright-license">AGPL-3.0</a>
      </p>
    </div>
  </div>
</footer>

<script>
  document.querySelector('.qq-group-link')?.addEventListener('click', async (e) => {
    e.preventDefault();
    const el = e.currentTarget as HTMLElement;
    const original = el.textContent ?? '';
    await navigator.clipboard.writeText(el.dataset.group!);
    el.textContent = document.documentElement.lang === 'zh' ? '群号已复制!' : 'Copied!';
    setTimeout(() => { el.textContent = original; }, 2000);
  });
</script>

<style>
  .footer {
    background: var(--color-bg-secondary);
    padding: 32px 0;
    border-top: 1px solid var(--color-border);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .footer-logo {
    width: 32px;
    height: 32px;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-links a {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    color: var(--color-text-secondary);
  }

  .footer-links a:hover {
    color: var(--color-text-primary);
  }

  .copyright {
    font-size: 13px;
    color: var(--color-text-muted);
  }

  .copyright-sep {
    margin: 0 4px;
    opacity: 0.5;
  }

  .copyright-license {
    color: var(--color-text-muted);
  }

  .copyright-license:hover {
    color: var(--color-text-secondary);
  }

  @media (max-width: 768px) {
    .footer-links {
      gap: 14px;
    }
  }
</style>

