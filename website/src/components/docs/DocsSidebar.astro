---
import { getDocsNav, type NavGroup } from '../../data/docs-nav';
import type { Lang } from '../../i18n/utils';

interface Props {
  lang: Lang;
  currentSlug: string;
}

const { lang, currentSlug } = Astro.props;
const navGroups = getDocsNav(lang as 'zh' | 'en');
---

<aside class="docs-sidebar" id="docs-sidebar">
  <div class="sidebar-header">
    <a href={lang === 'zh' ? '/zh/docs/getting-started/what-is-sailfish/' : '/docs/getting-started/what-is-sailfish/'} class="sidebar-brand">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
        <path d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
      </svg>
      {lang === 'zh' ? '文档' : 'Docs'}
    </a>
  </div>
  <nav class="sidebar-nav">
    {navGroups.map((group) => (
      <div class="nav-group">
        <div class="nav-group-label">{group.label}</div>
        <ul class="nav-group-items">
          {group.items.map((item) => {
            const href = lang === 'zh' ? `/zh/docs/${item.slug}/` : `/docs/${item.slug}/`;
            const isActive = currentSlug === item.slug;
            return (
              <li>
                <a href={href} class:list={['nav-item', { active: isActive }]}>
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>
</aside>

<style>
  .docs-sidebar {
    width: 260px;
    flex-shrink: 0;
    position: fixed;
    top: 73px;
    left: 0;
    bottom: 0;
    overflow-y: auto;
    padding: 24px 16px 48px;
    border-right: 1px solid var(--color-border);
    background: var(--color-bg-primary);
    z-index: 100;
  }

  .sidebar-header {
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--color-border);
  }

  .sidebar-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .sidebar-brand:hover {
    color: var(--color-accent-primary);
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .nav-group-label {
    font-size: 12px;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0 12px;
    margin-bottom: 6px;
  }

  .nav-group-items {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-item {
    display: block;
    padding: 6px 12px;
    font-size: 14px;
    color: var(--color-text-secondary);
    border-radius: var(--radius-sm);
    transition: all 0.15s ease;
    line-height: 1.5;
  }

  .nav-item:hover {
    color: var(--color-text-primary);
    background: var(--color-bg-tertiary);
  }

  .nav-item.active {
    color: var(--color-accent-primary);
    background: rgba(6, 182, 212, 0.08);
    font-weight: 500;
  }

  /* Mobile */
  @media (max-width: 1024px) {
    .docs-sidebar {
      display: none;
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: 280px;
      padding-top: 80px;
      z-index: 999;
      box-shadow: 4px 0 24px rgba(0, 0, 0, 0.5);
    }

    .docs-sidebar.open {
      display: block;
    }
  }
</style>
