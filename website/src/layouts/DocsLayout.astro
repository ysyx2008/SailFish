---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DocsSidebar from '../components/docs/DocsSidebar.astro';
import DocsToc from '../components/docs/DocsToc.astro';
import DocsPrevNext from '../components/docs/DocsPrevNext.astro';
import type { Lang } from '../i18n/utils';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  currentSlug: string;
  headings: Heading[];
}

const { title, description, lang, currentSlug, headings } = Astro.props;
const tocLabel = lang === 'zh' ? '本页目录' : 'On this page';
---

<Layout title={`${title} - ${lang === 'zh' ? '旗鱼文档' : 'SailFish Docs'}`} description={description} lang={lang}>
  <Header lang={lang} />

  <!-- Mobile sidebar toggle -->
  <button class="sidebar-toggle" id="sidebar-toggle" aria-label="Toggle sidebar">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
      <path d="M4 6h16M4 12h16M4 18h16"/>
    </svg>
  </button>

  <div class="docs-wrapper">
    <DocsSidebar lang={lang} currentSlug={currentSlug} />

    <div class="docs-main">
      <article class="docs-article">
        <slot />
        <DocsPrevNext lang={lang} currentSlug={currentSlug} />
      </article>

      <DocsToc headings={headings} label={tocLabel} />
    </div>
  </div>

  <div class="docs-footer-wrapper">
    <Footer lang={lang} />
  </div>
</Layout>

<style is:global>
  /* Sidebar toggle (mobile) */
  .sidebar-toggle {
    display: none;
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 1000;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    color: var(--color-text-primary);
    cursor: pointer;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
  }

  @media (max-width: 1024px) {
    .sidebar-toggle { display: flex; }
  }

  .sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 998;
    background: rgba(0, 0, 0, 0.5);
  }

  .sidebar-overlay.open { display: block; }

  /* Docs wrapper */
  .docs-wrapper {
    display: flex;
    min-height: calc(100vh - 73px);
    padding-top: 73px;
  }

  .docs-main {
    flex: 1;
    display: flex;
    gap: 24px;
    margin-left: 260px;
    padding: 40px 40px 80px;
    min-width: 0;
    max-width: calc(100% - 260px);
  }

  .docs-article {
    flex: 1;
    min-width: 0;
    max-width: 780px;
  }

  .docs-footer-wrapper {
    margin-left: 260px;
  }

  /* Markdown content styling */
  .docs-article h1 {
    font-size: 32px;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .docs-article > p:first-of-type {
    font-size: 17px;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .docs-article h2 {
    font-size: 24px;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-top: 48px;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--color-border);
    scroll-margin-top: 90px;
  }

  .docs-article h3 {
    font-size: 18px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-top: 32px;
    margin-bottom: 12px;
    scroll-margin-top: 90px;
  }

  .docs-article h4 {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-top: 24px;
    margin-bottom: 8px;
  }

  .docs-article p {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 16px;
  }

  .docs-article ul,
  .docs-article ol {
    padding-left: 24px;
    margin-bottom: 16px;
  }

  .docs-article li {
    font-size: 15px;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 6px;
  }

  .docs-article li::marker {
    color: var(--color-accent-primary);
  }

  .docs-article strong {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .docs-article code {
    font-family: var(--font-mono);
    font-size: 13px;
    padding: 2px 6px;
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-accent-primary);
  }

  .docs-article pre {
    margin-bottom: 16px;
    padding: 16px 20px;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow-x: auto;
  }

  .docs-article pre code {
    padding: 0;
    background: none;
    border: none;
    font-size: 13px;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  .docs-article blockquote {
    margin: 16px 0;
    padding: 12px 20px;
    border-left: 3px solid var(--color-accent-primary);
    background: rgba(6, 182, 212, 0.05);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .docs-article blockquote p {
    margin-bottom: 0;
    color: var(--color-text-secondary);
    font-size: 14px;
  }

  .docs-article a {
    color: var(--color-accent-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .docs-article a:hover {
    color: var(--color-accent-secondary);
  }

  .docs-article table {
    width: 100%;
    margin-bottom: 16px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    border-collapse: collapse;
    overflow: hidden;
  }

  .docs-article th,
  .docs-article td {
    padding: 10px 16px;
    font-size: 14px;
    border-bottom: 1px solid var(--color-border);
    text-align: left;
  }

  .docs-article th {
    font-weight: 600;
    color: var(--color-text-primary);
    background: var(--color-bg-tertiary);
  }

  .docs-article td {
    color: var(--color-text-secondary);
  }

  .docs-article tr:last-child td {
    border-bottom: none;
  }

  .docs-article img {
    max-width: 100%;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    margin: 16px 0;
  }

  .docs-article hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 32px 0;
  }

  /* Tip/Warning/Info boxes via blockquote with emoji prefix */
  .docs-article .callout {
    margin: 16px 0;
    padding: 16px 20px;
    border-radius: var(--radius-md);
    border: 1px solid;
  }

  .docs-article .callout-tip {
    border-color: rgba(34, 197, 94, 0.3);
    background: rgba(34, 197, 94, 0.05);
  }

  .docs-article .callout-warning {
    border-color: rgba(234, 179, 8, 0.3);
    background: rgba(234, 179, 8, 0.05);
  }

  .docs-article .callout-info {
    border-color: rgba(6, 182, 212, 0.3);
    background: rgba(6, 182, 212, 0.05);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .docs-main {
      margin-left: 0;
      max-width: 100%;
      padding: 32px 24px 80px;
    }

    .docs-footer-wrapper {
      margin-left: 0;
    }
  }

  @media (max-width: 768px) {
    .docs-article h1 { font-size: 26px; }
    .docs-article h2 { font-size: 20px; }
    .docs-main { padding: 24px 16px 80px; }
  }
</style>

<script>
  const toggle = document.getElementById('sidebar-toggle');
  const sidebar = document.getElementById('docs-sidebar');

  if (toggle && sidebar) {
    let overlay = document.querySelector('.sidebar-overlay') as HTMLElement;
    if (!overlay) {
      overlay = document.createElement('div');
      overlay.className = 'sidebar-overlay';
      document.body.appendChild(overlay);
    }

    function closeSidebar() {
      sidebar!.classList.remove('open');
      overlay!.classList.remove('open');
    }

    toggle.addEventListener('click', () => {
      const isOpen = sidebar!.classList.contains('open');
      if (isOpen) {
        closeSidebar();
      } else {
        sidebar!.classList.add('open');
        overlay!.classList.add('open');
      }
    });

    overlay.addEventListener('click', closeSidebar);
  }
</script>
